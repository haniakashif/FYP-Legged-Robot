  author = {Spiridonov, Alexander and Buehler, Fabio and Berclaz, Moriz and Schelbert, Valerio and Geurts, Jorit and Krasnova, Elena and Steinke, Emma and Toma, Jonas and Wuethrich, Joschua and Polat, Recep and Zimmermann, Wim and Arm, Philip and Rudin, Nikita and Kolvenbach, Hendrik and Hutter, Marco},
  year = 2024,
