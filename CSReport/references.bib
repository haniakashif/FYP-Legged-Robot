  booktitle = {Collection of Selected Papers of the {{IV International Conference}} on {{Information Technology}} and {{Nanotechnology}}},
  author = {{Federal Research Centre of Biological Systems and Agro-technologies of the Russian Academy of Sciences, 9 Yanvarya street 29, Orenburg, Russia, 460000} and Ruchay, Alexey and {Department of Mathematics, Chelyabinsk State University, Bratiev Kashirinykh street 129, Chelyabinsk, Russia, 454001} and Dorofeev, Konstantin and {Department of Mathematics, Chelyabinsk State University, Bratiev Kashirinykh street 129, Chelyabinsk, Russia, 454001} and Kober, Anastasia and {Federal Research Centre of Biological Systems and Agro-technologies of the Russian Academy of Sciences, 9 Yanvarya street 29, Orenburg, Russia, 460000}},
