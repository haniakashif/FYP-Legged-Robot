@article{irawanOptimalImpedanceControl2011,
  title = {Optimal Impedance Control Based on Body Inertia for a Hydraulically Driven Hexapod Robot Walking on Uneven and Extremely Soft Terrain},
  author = {Irawan, Addie and Nonami, Kenzo},
  year = 2011,
  journal = {Journal of Field Robotics},
