  shorttitle = {Learning-Based Legged Locomotion},
  author = {Ha, Sehoon and Lee, Joonho and {van de Panne}, Michiel and Xie, Zhaoming and Yu, Wenhao and Khadiv, Majid},
  year = 2025,
